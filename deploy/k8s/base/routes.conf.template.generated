# task-071: WZ uploads now flow through atlas-data. The `^~` modifier is
# load-bearing: nginx evaluates regex locations before plain prefixes, so
# without it the regex catch-all `location ~ ^/api/data(/.*)?$` below wins
# and the 4G body-size + no-request-buffering overrides are bypassed (413
# at the default 1 MB on a multi-hundred-MB atlas.zip).
location ^~ /api/data/wz {
  client_max_body_size 4G;
  proxy_request_buffering off;
  proxy_read_timeout 3600;
  proxy_send_timeout 3600;
  send_timeout 3600;
  set $u "atlas-data.${POD_NAMESPACE}.svc.cluster.local:8080";
  proxy_pass http://$u$request_uri;
}

