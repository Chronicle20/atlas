# --- task-071: asset routing rewrite ----------------------------------------
# /api/assets is split into three layered locations:
#   1. character render  -> atlas-renders   (most specific; matched first)
#   2. map render        -> minio (cache hit)  | atlas-renders (cache miss)
#   3. generic asset     -> minio (per-tenant) | minio (shared fallback)
#
# Note: 'upstream' directives cannot appear in this file because routes.conf
# is included inside a server{} block. We use direct service:port references
# (matching the existing convention in this file).
# ----------------------------------------------------------------------------

# 1. Character render (most specific; must match before the generic assets block).
# Hostname is held in $u so nginx defers DNS resolution to request time
# (matches the convention in the rest of this file).
location ~ "^/api/assets/(?<tenant>[^/]+)/(?<region>[^/]+)/(?<v>[0-9]+\.[0-9]+)/character/(?<hash>[a-f0-9]{32,64})\.png$" {
  set $major "";
  set $minor "";
  if ($v ~ ^(?<maj>[0-9]+)\.(?<min>[0-9]+)$) {
    set $major $maj;
    set $minor $min;
  }
  proxy_set_header TENANT_ID     $tenant;
  proxy_set_header REGION        $region;
  proxy_set_header MAJOR_VERSION $major;
  proxy_set_header MINOR_VERSION $minor;
  set $u "atlas-renders.${POD_NAMESPACE}.svc.cluster.local:8080";
  proxy_pass http://$u/api/wz/character/render/$tenant/$region/$v/$hash.png$is_args$args;
  add_header Cache-Control "public, max-age=86400, immutable" always;
}

# 2. Map render (atlas-renders composites on miss; MinIO serves cache hits).
location ~ ^/api/assets/(?<t>[^/]+)/(?<r>[^/]+)/(?<v>[0-9]+\.[0-9]+)/map/(?<mapid>[0-9]+)/render\.png$ {
  set $major "";
  set $minor "";
  if ($v ~ ^(?<maj>[0-9]+)\.(?<min>[0-9]+)$) {
    set $major $maj;
    set $minor $min;
  }
  # MinIO lives in the `minio` namespace; the bare hostname resolves against
  # ingress's own namespace search path (atlas-pr-544 / atlas-main) and fails
  # with NXDOMAIN. Qualify with the namespace.
  #
  # `set` must come BEFORE `rewrite ... break;` — the `break` flag ends
  # the rewrite phase, so any `set` placed after it is never executed
  # and `$u` ends up empty at proxy_pass time (nginx 500: "invalid URL
  # prefix in 'http://'"). Same fix as the generic-assets block below.
  set $u "minio.minio.svc.cluster.local:9000";
  rewrite ^ /atlas-renders/tenants/$t/regions/$r/versions/$v/map/$mapid/render.png break;
  proxy_intercept_errors on;
  error_page 404 = @maprender_miss;
  proxy_pass http://$u;
  add_header Cache-Control "public, max-age=86400, immutable" always;
}
location @maprender_miss {
  # atlas-renders' tenant middleware requires these four headers (see
  # services/atlas-renders/atlas.com/renders/main.go:50-66). Without them,
  # cache-miss requests 400 — same fix shape as the character-render block
  # above. $major/$minor are split out of $v in the outer location.
  proxy_set_header TENANT_ID     $t;
  proxy_set_header REGION        $r;
  proxy_set_header MAJOR_VERSION $major;
  proxy_set_header MINOR_VERSION $minor;
  # The outer location enables proxy_intercept_errors on so the MinIO
  # cache-miss 404 routes here. nginx inherits that setting unless we
  # explicitly turn it off, which would otherwise re-intercept any 4xx
  # atlas-renders legitimately returns (404 when layout.json doesn't
  # exist for a map that ingest never reached) and rewrite it as a
  # generic 400 because there's no error_page handler in this block.
  # Atlas-renders is the source of truth for its own status codes; we
  # want them to pass through untouched.
  proxy_intercept_errors off;
  set $u "atlas-renders.${POD_NAMESPACE}.svc.cluster.local:8080";
  proxy_pass http://$u/api/wz/map/render/$t/$r/$v/$mapid/render.png;
  add_header Cache-Control "public, max-age=86400, immutable" always;
}

# 3. Generic assets - per-tenant -> shared fallback against MinIO.
location ~ ^/api/assets/(?<t>[^/]+)/(?<r>[^/]+)/(?<v>[0-9]+\.[0-9]+)/(?<rest>.+)$ {
  # `set` must come BEFORE `rewrite ... break;`. The `break` flag ends
  # the rewrite phase, so any `set` placed after it is never executed —
  # `$u` ends up empty at proxy_pass time and nginx serves 500 with
  # `invalid URL prefix in "http://"` for every asset request. Pre-existed
  # since task-071's MinIO-direct asset routing landed; first observed on
  # PR 601 (task-076 ephemeral) when a UI client requested item icons.
  set $u "minio.minio.svc.cluster.local:9000";
  rewrite ^ /atlas-assets/tenants/$t/regions/$r/versions/$v/$rest break;
  proxy_intercept_errors on;
  error_page 404 = @shared_fallback;
  proxy_pass http://$u;
  add_header Cache-Control "public, max-age=86400" always;
}
location @shared_fallback {
  set $u "minio.minio.svc.cluster.local:9000";
  rewrite ^ /atlas-assets/shared/regions/$r/versions/$v/$rest break;
  proxy_pass http://$u;
  add_header Cache-Control "public, max-age=86400" always;
}
# --- end task-071 asset routing rewrite -------------------------------------

