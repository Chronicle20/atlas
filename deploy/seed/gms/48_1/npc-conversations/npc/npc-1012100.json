              {
                "nextState": null,
                "text": "Exit"
              }
            ],
            "dialogueType": "sendNextPrev",
            "text": "Now a reminder. Once you have chosen, you cannot change up your mind and try to pick another path. Go now, and live as a proud Bowman."
          },
          "id": "firstJobSuccess3",
          "type": "dialogue"
        },
