      "questId": 2307,
      "questName": "Kingdom of Mushroom in Danger",
      "startStateMachine": {
        "startState": "askAccept",
        "states": [
          {
            "dialogue": {
              "choices": [
                {
                  "nextState": "intro1",
                  "text": "Accept"
                },
