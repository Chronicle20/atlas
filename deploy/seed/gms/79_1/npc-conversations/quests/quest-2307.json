                  "nextState": null,
                  "text": "Exit"
                }
              ],
              "dialogueType": "sendNext",
              "text": "Hmmm? Is that a #brecommendation letter from the job instructor#k??! What is this, are you the one that came to save us, the Kingdom of Mushroom?"
