                }
              ],
              "dialogueType": "sendNextPrev",
              "speaker": "CHARACTER",
              "text": "I hear you are the best blacksmith in all of Maple World! I want nothing less than a weapon made by you!"
            },
            "id": "playerResponse2",
            "type": "dialogue"
          },
          {
            "dialogue": {
