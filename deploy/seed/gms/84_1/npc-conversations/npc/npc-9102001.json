      "startState": "start",
      "states": [
        {
          "id": "start",
          "type": "genericAction",
          "genericAction": {
            "operations": [
              {
                "type": "local:enumerate_evolvable_pets",
                "params": {
                  "outputContextKey": "evolvablePets",
                  "labelContextKey": "evolvablePetLabels",
                  "countContextKey": "evolvableCount"
                }
              }
            ],
            "outcomes": [
              {
