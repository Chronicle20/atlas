                },
                {
                  "nextState": null,
                  "text": "Exit"
                }
              ],
              "dialogueType": "sendNextPrev",
              "text": "Hm, how about trying out that sword? Wouldn't that bring back some memories? How about #bfighthing some monsters#k?"
