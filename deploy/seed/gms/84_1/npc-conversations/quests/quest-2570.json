                },
                {
                  "nextState": null,
                  "text": "Exit"
                }
              ],
              "dialogueType": "sendAcceptDecline",
              "text": "Now, it's all up to you. Do you wish to join the pirates? I would be quite pleased if you became a Cannoneer. "
            },
            "id": "askJoin",
            "type": "dialogue"
          },
