            "id": "nowPirate",
            "type": "dialogue"
          },
          {
            "dialogue": {
              "choices": [
                {
                  "nextState": "nowPirate",
                  "text": "Previous"
                },
                {
                  "nextState": "giftSlots",
                  "text": "Next"
