            "listSelection": {
              "choices": [
                {
                  "nextState": "explainPets",
                  "text": "What duties? Who are you?"
                },
                {
                  "nextState": null,
                  "text": "Exit"
                }
              ],
              "title": "Hello, traveler... You have finally come to see me. Have you fulfilled your duties?"
