        ]
      }
    },
    {
      "id": "default_loop_back",
      "conditions": [],
      "onMatch": {
        "allow": true,
        "operations": [
          { "type": "play_portal_sound" },
          { "type": "warp", "params": { "mapId": "222010200", "portalName": "east00" } }
        ]
      }
    }
  ]
